# CodeAdapt frontend environment variables.
# Copy this file to `.env.local` and fill in real values for local dev.
# All variables must be prefixed with `VITE_` to be exposed to the client.

# Backend API base URL. Leave empty to run fully on the in-memory mock.
# Example: http://localhost:8000/api
VITE_API_URL=

# HTTP request timeout (milliseconds).
VITE_API_TIMEOUT_MS=15000

# When "true", API calls are routed through the mock adapter.
# Set to "false" once the backend is wired up.
VITE_ENABLE_MOCK_API=true

# When "true", lightweight analytics events will be emitted.
VITE_ENABLE_ANALYTICS=false

# Logger verbosity: debug | info | warn | error | silent
VITE_LOG_LEVEL=debug
